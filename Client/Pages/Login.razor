@inject HttpClient Http
@inject AccessibilityMap.Services.AuthState Auth

<div class="login-overlay">
    <div class="login-card">
        <h3>♿ Карта доступности</h3>
        <p class="muted">Войдите в систему</p>
        <div class="field">
            <label class="form-label">Логин:</label>
            <input @bind="login" @bind:event="oninput" class="form-control" />
        </div>
        <div class="field">
            <label class="form-label">Пароль:</label>
            <input type="password" @bind="password" @bind:event="oninput" class="form-control" />
        </div>
        <div class="field">
            <label class="form-label">Проверка (капча): <b>@captchaQuestion</b></label>
            <input @bind="captchaAnswer" @bind:event="oninput" class="form-control" placeholder="Введите ответ" />
        </div>
        <button class="btn btn-primary" @onclick="DoLogin">Войти</button>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }
    </div>
</div>

@code {
    private string login = "";
    private string password = "";
    private string captchaToken = "";
    private string captchaQuestion = "";
    private string captchaAnswer = "";
    private string error = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCaptcha();
    }

    private async Task LoadCaptcha()
    {
        try
        {
            var c = await Http.GetFromJsonAsync<CaptchaResult>("/api/auth/captcha");
            if (c != null)
            {
                captchaToken = c.token;
                captchaQuestion = c.question;
                captchaAnswer = "";
            }
        }
        catch { }
    }

    private async Task DoLogin()
    {
        error = "";
        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login",
                new { Login = login, Password = password, CaptchaToken = captchaToken, CaptchaAnswer = captchaAnswer });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result != null)
                {
                    await Auth.SetAsync(result.Token, result.UserName, result.Role);
                }
            }
            else
            {
                try
                {
                    var err = await response.Content.ReadFromJsonAsync<ErrorResult>();
                    error = err?.error ?? "Неверный логин или пароль";
                }
                catch
                {
                    error = "Неверный логин или пароль";
                }
                await LoadCaptcha(); // при ошибке — новая капча
            }
        }
        catch (Exception ex)
        {
            error = "Ошибка входа: " + ex.Message;
        }
    }

    public class LoginResult
    {
        public string Token { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Role { get; set; } = "";
    }

    public class ErrorResult
    {
        public string? error { get; set; }
    }

    public class CaptchaResult
    {
        public string token { get; set; } = "";
        public string question { get; set; } = "";
    }
}
