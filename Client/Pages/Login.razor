@page "/login"
@inject NavigationManager Nav
@inject HttpClient Http
@inject AccessibilityMap.Services.AuthState Auth

<div class="login-page">
    <div class="login-card">
        <h3>♿ Карта доступности</h3>
        <p class="muted">Войдите в систему</p>
        <div class="field">
            <label class="form-label">Логин:</label>
            <input @bind="login" @bind:event="oninput" class="form-control" autocomplete="username" />
        </div>
        <div class="field">
            <label class="form-label">Пароль:</label>
            <div class="password-row">
                <input type="@(showPassword ? "text" : "password")" @bind="password" @bind:event="oninput" class="form-control" autocomplete="current-password" />
                <button type="button" class="btn btn-secondary password-toggle" @onclick="@(() => showPassword = !showPassword)">@(showPassword ? "🙈" : "👁️")</button>
            </div>
        </div>
        <div class="field">
            <label class="form-label">Проверка (капча): <b>@captchaQuestion</b></label>
            <input @bind="captchaAnswer" @bind:event="oninput" class="form-control" placeholder="Введите ответ" />
        </div>
        <button class="btn btn-primary" disabled="@isLoggingIn" @onclick="DoLogin">@(isLoggingIn ? "Входим..." : "Войти")</button>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }
    </div>
</div>

@code {
    private string login = "";
    private string password = "";
    private string captchaToken = "";
    private string captchaQuestion = "";
    private string captchaAnswer = "";
    private string error = "";
    private bool showPassword = false;
    private bool isLoggingIn = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCaptcha();
    }

    private async Task LoadCaptcha()
    {
        try
        {
            var c = await Http.GetFromJsonAsync<CaptchaResult>("/api/auth/captcha");
            if (c != null)
            {
                captchaToken = c.token;
                captchaQuestion = c.question;
                captchaAnswer = "";
            }
        }
        catch { }
    }

    private async Task DoLogin()
    {
        if (isLoggingIn) return;
        error = "";
        isLoggingIn = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login",
                new { Login = login.Trim(), Password = password.Trim(), CaptchaToken = captchaToken, CaptchaAnswer = captchaAnswer.Trim() });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result != null)
                {
                    await Auth.SetAsync(result.Token, result.UserName, result.Role, result.ProfileComplete);
                    Nav.NavigateTo("/", replace: true);
                }
            }
            else
            {
                try
                {
                    var err = await response.Content.ReadFromJsonAsync<ErrorResult>();
                    error = err?.error ?? "Неверный логин или пароль";
                }
                catch
                {
                    error = "Неверный логин или пароль";
                }
                await LoadCaptcha();
            }
        }
        catch (Exception ex)
        {
            error = "Ошибка входа: " + ex.Message;
            await LoadCaptcha();
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    public class LoginResult
    {
        public string Token { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Role { get; set; } = "";
        public bool ProfileComplete { get; set; } = true;
    }

    public class ErrorResult
    {
        public string? error { get; set; }
    }

    public class CaptchaResult
    {
        public string token { get; set; } = "";
        public string question { get; set; } = "";
    }
}
