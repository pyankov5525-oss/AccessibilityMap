@page "/users"
@inject HttpClient Http
@inject AccessibilityMap.Services.AuthState Auth

<h3>Управление пользователями</h3>
<p>Вы вошли как: <b>@RoleRu(Auth.Role)</b></p>

@if (Auth.Role == "Developer")
{
    <div class="form-card" style="max-width:440px;">
        <h5>Создать управляющего или разработчика</h5>
        <div class="field">
            <select @bind="newRole" class="form-control">
                <option value="Manager">Управляющий</option>
                <option value="Developer">Разработчик</option>
            </select>
        </div>
        <button class="btn btn-primary" @onclick="CreateManagerOrDev">Создать</button>
    </div>
}
else if (Auth.Role == "Manager")
{
    <div class="form-card" style="max-width:440px;">
        <h5>Создать волонтёра</h5>
        <button class="btn btn-primary" @onclick="CreateVolunteer">Создать волонтёра</button>
    </div>
}
else
{
    <p class="muted">Нет доступа.</p>
}

@if (created != null)
{
    <div class="alert alert-success" style="max-width:440px; margin-top:12px;">
        Создан аккаунт:<br />
        Логин: <b>@created.Login</b><br />
        Пароль: <b>@created.Password</b><br />
        Роль: @created.Role
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-warning" style="max-width:440px; margin-top:12px;">@message</div>
}

@if (loading)
{
    <p>Загрузка пользователей...</p>
}
else
{
    <div class="page">
        <h5>Разработчики</h5>
        <table class="places-table">
            <thead><tr><th>Логин</th><th>Роль</th><th></th></tr></thead>
            <tbody>
            @foreach (var u in users.Where(x => x.Role == "Developer").ToList())
            {
                bool isSelf = u.UserName == Auth.UserName;
                <tr>
                    <td>@(u.UserName + (isSelf ? " (вы)" : ""))</td>
                    <td>
                        @if (Auth.Role == "Developer")
                        {
                            <select class="form-control form-control-sm" @onchange="e => ChangeRole(u.Id, e.Value?.ToString() ?? "")">
                                @foreach (var r in new[] { "Developer", "Manager", "Volunteer" })
                                {
                                    @if (r == u.Role)
                                    {
                                        <option value="@r" selected>@RoleRu(r)</option>
                                    }
                                    else
                                    {
                                        <option value="@r">@RoleRu(r)</option>
                                    }
                                }
                            </select>
                        }
                        else
                        {
                            @RoleRu(u.Role)
                        }
                    </td>
                    <td class="row-actions">
                        <button class="btn btn-sm btn-danger" disabled="@isSelf" @onclick="() => DeleteUser(u.Id)">Удалить</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <h5>Управляющие</h5>
        <table class="places-table">
            <thead><tr><th>Логин</th><th>Роль</th><th></th></tr></thead>
            <tbody>
            @foreach (var u in users.Where(x => x.Role == "Manager").ToList())
            {
                bool isSelf = u.UserName == Auth.UserName;
                <tr>
                    <td>@(u.UserName + (isSelf ? " (вы)" : ""))</td>
                    <td>
                        @if (Auth.Role == "Developer")
                        {
                            <select class="form-control form-control-sm" @onchange="e => ChangeRole(u.Id, e.Value?.ToString() ?? "")">
                                @foreach (var r in new[] { "Developer", "Manager", "Volunteer" })
                                {
                                    @if (r == u.Role)
                                    {
                                        <option value="@r" selected>@RoleRu(r)</option>
                                    }
                                    else
                                    {
                                        <option value="@r">@RoleRu(r)</option>
                                    }
                                }
                            </select>
                        }
                        else
                        {
                            @RoleRu(u.Role)
                        }
                    </td>
                    <td class="row-actions">
                        <button class="btn btn-sm btn-danger" disabled="@isSelf" @onclick="() => DeleteUser(u.Id)">Удалить</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <h5>Волонтёры</h5>
        <table class="places-table">
            <thead><tr><th>Логин</th><th>Роль</th><th></th></tr></thead>
            <tbody>
            @foreach (var u in users.Where(x => x.Role == "Volunteer").ToList())
            {
                bool isSelf = u.UserName == Auth.UserName;
                <tr>
                    <td>@(u.UserName + (isSelf ? " (вы)" : ""))</td>
                    <td>
                        @if (Auth.Role == "Developer")
                        {
                            <select class="form-control form-control-sm" @onchange="e => ChangeRole(u.Id, e.Value?.ToString() ?? "")">
                                @foreach (var r in new[] { "Developer", "Manager", "Volunteer" })
                                {
                                    @if (r == u.Role)
                                    {
                                        <option value="@r" selected>@RoleRu(r)</option>
                                    }
                                    else
                                    {
                                        <option value="@r">@RoleRu(r)</option>
                                    }
                                }
                            </select>
                        }
                        else
                        {
                            @RoleRu(u.Role)
                        }
                    </td>
                    <td class="row-actions">
                        <button class="btn btn-sm btn-danger" disabled="@isSelf" @onclick="() => DeleteUser(u.Id)">Удалить</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private string newRole = "Manager";
    private CreatedUser? created;
    private List<UserRow> users = new();
    private bool loading = true;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        loading = false;
    }

    private async Task LoadUsers()
    {
        try
        {
            var resp = await Http.GetAsync("/api/auth/users");
            if (resp.IsSuccessStatusCode)
            {
                users = await resp.Content.ReadFromJsonAsync<List<UserRow>>() ?? new List<UserRow>();
            }
            else
            {
                users = new List<UserRow>();
            }
        }
        catch
        {
            users = new List<UserRow>();
        }
    }

    private async Task ChangeRole(string id, string role)
    {
        if (string.IsNullOrEmpty(role)) return;
        var resp = await Http.PostAsJsonAsync($"/api/auth/{id}/role", new { Role = role });
        if (!resp.IsSuccessStatusCode)
        {
            var err = await resp.Content.ReadFromJsonAsync<ErrorResult>();
            message = err?.Error ?? "Не удалось сменить роль";
        }
        else
        {
            message = "";
        }
        await LoadUsers();
        StateHasChanged();
    }

    private async Task DeleteUser(string id)
    {
        var resp = await Http.DeleteAsync($"/api/auth/{id}");
        if (!resp.IsSuccessStatusCode)
        {
            var err = await resp.Content.ReadFromJsonAsync<ErrorResult>();
            message = err?.Error ?? "Не удалось удалить";
        }
        else
        {
            message = "";
        }
        await LoadUsers();
        StateHasChanged();
    }

    private async Task CreateManagerOrDev()
    {
        var res = await Http.PostAsJsonAsync("/api/auth/create", new { Role = newRole });
        if (res.IsSuccessStatusCode) created = await res.Content.ReadFromJsonAsync<CreatedUser>();
    }

    private async Task CreateVolunteer()
    {
        var res = await Http.PostAsJsonAsync("/api/auth/create-volunteer", new { });
        if (res.IsSuccessStatusCode) created = await res.Content.ReadFromJsonAsync<CreatedUser>();
    }

    private string RoleRu(string r) => r switch
    {
        "Developer" => "Разработчик",
        "Manager" => "Управляющий",
        "Volunteer" => "Волонтёр",
        _ => r
    };

    public class UserRow
    {
        public string Id { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Role { get; set; } = "";
    }

    public class CreatedUser
    {
        public string Login { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "";
    }

    public class ErrorResult
    {
        public string Error { get; set; } = "";
    }
}
