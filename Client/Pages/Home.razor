@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AccessibilityMap.Services.AuthState Auth
@implements IDisposable

<div class="map-page">
    <div id="map" class="map"></div>

    @* Фильтры — накладываются поверх карты (по центру сверху) *@
    <div class="map-filters">
        <button class="chip @(currentFilter == "all" ? "chip-active" : "")" @onclick="SetFilterAll">Все</button>
        <button class="chip chip-green @(currentFilter == "green" ? "chip-active" : "")" @onclick="SetFilterGreen">🟢 Доступно</button>
        <button class="chip chip-gold @(currentFilter == "gold" ? "chip-active" : "")" @onclick="SetFilterGold">🟡 Частично</button>
        <button class="chip chip-red @(currentFilter == "red" ? "chip-active" : "")" @onclick="SetFilterRed">🔴 Недоступно</button>
    </div>

    @if (showCounter)
    {
        <div class="map-stats">
            <div class="stat"><b>@totalCount</b><span>всего</span></div>
            <div class="stat stat-green"><b>@greenCount</b><span>доступно</span></div>
            <div class="stat stat-gold"><b>@goldCount</b><span>частично</span></div>
            <div class="stat stat-red"><b>@redCount</b><span>недоступно</span></div>
        </div>
    }

    @if (verifyMode)
    {
        <div class="map-banner">🔍 Проверка меток включена — показаны только серые метки на модерации.</div>
    }
    else if (accessibilityMode)
    {
        <div class="map-banner">♿ Режим доступности включён — показаны одобренные метки. Кликните по карте, чтобы добавить объект.</div>
    }
    else
    {
        <div class="map-hint">Выберите переключатель «Доступность» или «Проверка меток» справа сверху.</div>
    }

    @if (showForm)
    {
        <div class="map-form-overlay">
            <div class="form-card">
                <h5 class="form-title">@(editingId.HasValue ? "Редактировать объект" : "Добавить объект")</h5>

                <div class="field">
                    <label class="form-label">Адрес:</label>
                    <input @bind="newPlacemark.Address" class="form-control" placeholder="ул. Ленина, 10, Воронеж" />
                </div>

                <div class="field">
                    <label class="form-label">Название:</label>
                    <input @bind="newPlacemark.Name" class="form-control" />
                </div>

                <div class="field">
                    <label class="form-label">Категория:</label>
                    <select @bind="newPlacemark.Category" class="form-control">
                        <option value="">Выберите...</option>
                        <option>Поликлиника</option>
                        <option>Аптека</option>
                        <option>Магазин</option>
                        <option>Администрация</option>
                        <option>Культура</option>
                        <option>Образование</option>
                        <option>Другое</option>
                    </select>
                </div>

                <h6 class="criteria-title">Критерии (0-3):</h6>
                <ScoreInput Label="Вход" @bind-value="newPlacemark.ScoreEntrance" />
                <ScoreInput Label="Ширина дверей" @bind-value="newPlacemark.ScoreDoorWidth" />
                <ScoreInput Label="Внутренние пути" @bind-value="newPlacemark.ScoreInternalPath" />
                <ScoreInput Label="Санитарная зона" @bind-value="newPlacemark.ScoreSanitary" />
                <ScoreInput Label="Информация" @bind-value="newPlacemark.ScoreInfo" />
                <ScoreInput Label="Парковка" @bind-value="newPlacemark.ScoreParking" />
                <ScoreInput Label="Персонал" @bind-value="newPlacemark.ScoreStaff" />

                <div class="field">
                    <label class="form-label">Фотография:</label>
                    <InputFile OnChange="OnFileSelected" accept="image/*" />
                    @if (!string.IsNullOrEmpty(newPlacemark.PhotoPath))
                    {
                        <div class="photo-preview">
                            <img src="/api/photos/@newPlacemark.PhotoPath" alt="фото объекта" />
                        </div>
                    }
                </div>

                <div class="field">
                    <label class="form-label">Примечания:</label>
                    <textarea @bind="newPlacemark.Notes" class="form-control" rows="2"></textarea>
                </div>

                <div class="form-actions">
                    <button class="btn btn-success" @onclick="AddPlacemark">@(editingId.HasValue ? "Сохранить" : "Добавить")</button>
                    <button class="btn btn-secondary" @onclick="CloseForm">Отмена</button>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
                }
            </div>
        </div>
    }
</div>

@code {

    private bool showForm = false;
    private int? editingId = null;
    private NewPlacemark newPlacemark = new();
    private string message = "";
    private bool isError = false;
    private DotNetObjectReference<Home>? dotNetRef;
    private bool accessibilityMode = false;
    private bool verifyMode = false;

    private int totalCount = 0;
    private int greenCount = 0;
    private int goldCount = 0;
    private int redCount = 0;
    private bool showCounter = false;

    private string currentFilter = "all";

    private const long MaxPhotoSize = 5 * 1024 * 1024;

    private async Task SetFilterAll() => await SetFilter("all");
    private async Task SetFilterGreen() => await SetFilter("green");
    private async Task SetFilterGold() => await SetFilter("gold");
    private async Task SetFilterRed() => await SetFilter("red");

    private async Task SetFilter(string filter)
    {
        currentFilter = filter;
        await JS.InvokeVoidAsync("setFilter", filter);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("setDotNetRef", dotNetRef);
                await JS.InvokeVoidAsync("setCanVerify", Auth.Role == "Developer" || Auth.Role == "Manager");
                await JS.InvokeVoidAsync("setCanManagePlacemarks", Auth.Role == "Developer" || Auth.Role == "Manager");
                await LoadPlacemarks();

                var query = new Uri(Navigation.Uri).Query;
                var editMatch = System.Text.RegularExpressions.Regex.Match(query, @"[?&]edit=(\d+)");
                if (editMatch.Success && int.TryParse(editMatch.Groups[1].Value, out int editId))
                {
                    await EditPlacemark(editId);
                }

                // Глубокая ссылка из «Проверки»: /?focus=<id> центрирует карту на метке
                var focusMatch = System.Text.RegularExpressions.Regex.Match(query, @"[?&]focus=(\d+)");
                if (focusMatch.Success && int.TryParse(focusMatch.Groups[1].Value, out int focusId))
                {
                    await Task.Delay(900);
                    await JS.InvokeVoidAsync("focusPlacemark", focusId);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Home init ошибка: " + ex.Message);
            }
        }
    }

    [JSInvokable]
    public void UpdateCounter(int total, int green, int gold, int red)
    {
        totalCount = total;
        greenCount = green;
        goldCount = gold;
        redCount = red;
        showCounter = total > 0;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnAccessibilityModeChanged(bool enabled)
    {
        accessibilityMode = enabled;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnVerifyModeChanged(bool enabled)
    {
        verifyMode = enabled;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnMapClickWithCoords(double lat, double lon)
    {
        try
        {
            var latStr = lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lonStr = lon.ToString(System.Globalization.CultureInfo.InvariantCulture);

            // Проверяем дубликат (в радиусе 50 м)
            var nearestResponse = await Http.GetAsync($"/api/placemarks/nearest?lat={latStr}&lon={lonStr}");
            if (nearestResponse.IsSuccessStatusCode)
            {
                var existing = await nearestResponse.Content.ReadFromJsonAsync<PlacemarkData>();
                if (existing != null && existing.Id > 0)
                {
                    await JS.InvokeVoidAsync("openBalloon", existing.Id);
                    return;
                }
            }

            // Открываем форму; адрес подставим через обратный геокодинг на сервере
            newPlacemark = new NewPlacemark
            {
                Latitude = lat,
                Longitude = lon
            };
            editingId = null;
            showForm = true;
            message = "";
            StateHasChanged();

            try
            {
                var revResp = await Http.GetAsync($"/api/placemarks/reverse-geocode?lat={latStr}&lon={lonStr}");
                if (revResp.IsSuccessStatusCode)
                {
                    var r = await revResp.Content.ReadFromJsonAsync<ReverseResult>();
                    if (r != null && !string.IsNullOrEmpty(r.address))
                    {
                        newPlacemark.Address = r.address;
                        StateHasChanged();
                    }
                }
            }
            catch { }
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnPoiClick(double lat, double lon, string name, string address)
    {
        try
        {
            newPlacemark = new NewPlacemark
            {
                Latitude = lat,
                Longitude = lon,
                Name = name ?? "",
                Address = address ?? ""
            };
            editingId = null;
            showForm = true;
            message = "";
            StateHasChanged();

            var latStr = lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lonStr = lon.ToString(System.Globalization.CultureInfo.InvariantCulture);
            try
            {
                var revResp = await Http.GetAsync($"/api/placemarks/reverse-geocode?lat={latStr}&lon={lonStr}");
                if (revResp.IsSuccessStatusCode)
                {
                    var r = await revResp.Content.ReadFromJsonAsync<ReverseResult>();
                    if (r != null && !string.IsNullOrEmpty(r.address))
                    {
                        newPlacemark.Address = r.address;
                        StateHasChanged();
                    }
                }
            }
            catch { }
        }
        catch { }
    }

    [JSInvokable]
    public async Task EditPlacemark(int id)
    {
        if (Auth.Role != "Developer" && Auth.Role != "Manager") return;
        try
        {
            var placemark = await Http.GetFromJsonAsync<PlacemarkData>($"/api/placemarks/{id}");
            if (placemark != null)
            {
                editingId = id;
                newPlacemark = new NewPlacemark
                {
                    Name = placemark.Name,
                    Address = placemark.Address,
                    Category = placemark.Category,
                    Latitude = placemark.Latitude,
                    Longitude = placemark.Longitude,
                    ScoreEntrance = placemark.Scores?.Entrance ?? 0,
                    ScoreDoorWidth = placemark.Scores?.DoorWidth ?? 0,
                    ScoreInternalPath = placemark.Scores?.InternalPath ?? 0,
                    ScoreSanitary = placemark.Scores?.Sanitary ?? 0,
                    ScoreInfo = placemark.Scores?.Info ?? 0,
                    ScoreParking = placemark.Scores?.Parking ?? 0,
                    ScoreStaff = placemark.Scores?.Staff ?? 0,
                    Notes = placemark.Notes,
                    PhotoPath = placemark.PhotoPath ?? ""
                };
                showForm = true;
                message = "";
                StateHasChanged();
            }
        }
        catch { }
    }

    [JSInvokable]
    public async Task DeletePlacemark(int id)
    {
        if (Auth.Role != "Developer" && Auth.Role != "Manager") return;
        await Http.DeleteAsync($"/api/placemarks/{id}");
        await LoadPlacemarks();
    }

    [JSInvokable]
    public async Task SearchAddress(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return;
        }

        // Геокодинг выполняется на сервере через HTTP-геокодер Яндекса.
        // Это не зависит от привязки JS-ключа карт к домену, поэтому поиск
        // работает и локально, и на хостинге (Render и т.п.).
        try
        {
            var resp = await Http.GetAsync($"/api/placemarks/geocode?address={System.Uri.EscapeDataString(query)}");
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<GeocodeResult>();
                if (r != null && !string.IsNullOrWhiteSpace(r.address) && Math.Abs(r.lat) > 1e-6)
                {
                    await OnGeocodeResult(r.lat, r.lon, r.address);
                    return;
                }
            }
            message = "Ничего не найдено по запросу";
            isError = true;
        }
        catch (Exception ex)
        {
            message = "Ошибка поиска: " + ex.Message;
            isError = true;
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task SearchSuggestions(string query)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length < 3) return;
        try
        {
            var resp = await Http.GetAsync($"/api/placemarks/suggest?q={System.Uri.EscapeDataString(query)}&limit=6");
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<SuggestionResult>();
                if (r != null)
                    await JS.InvokeVoidAsync("showSuggestions", r.items ?? new List<GeocodeSuggestItem>());
            }
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnGeocodeResult(double lat, double lon, string text)
    {
        if (string.IsNullOrWhiteSpace(text) || (Math.Abs(lat) < 1e-6 && Math.Abs(lon) < 1e-6))
        {
            message = "Ничего не найдено";
            isError = true;
            StateHasChanged();
            return;
        }

        await JS.InvokeVoidAsync("moveMapTo", lat, lon);
        newPlacemark = new NewPlacemark
        {
            Latitude = lat,
            Longitude = lon,
            Address = text
        };
        editingId = null;
        showForm = true;
        message = "Заполните данные объекта";
        isError = false;
        StateHasChanged();
    }

    private async Task LoadPlacemarks()
    {
        try
        {
            var resp = await Http.GetAsync("/api/placemarks");
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                Console.WriteLine($"API /api/placemarks вернул {resp.StatusCode}. Тело (первые 200 симв.): {err.Substring(0, Math.Min(200, err.Length))}");
                return;
            }
            var placemarks = await resp.Content.ReadFromJsonAsync<List<PlacemarkData>>();
            await JS.InvokeVoidAsync("updatePlacemarks", placemarks ?? new List<PlacemarkData>());
        }
        catch (Exception ex)
        {
            Console.WriteLine("LoadPlacemarks ошибка: " + ex.Message);
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(MaxPhotoSize).CopyToAsync(ms);

            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(ms.ToArray()), "file", file.Name);

            var response = await Http.PostAsync("/api/photos", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PhotoUploadResult>();
                newPlacemark.PhotoPath = result?.FileName ?? "";
                message = "Фото загружено ✅";
                isError = false;
            }
            else
            {
                message = "Не удалось загрузить фото";
                isError = true;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = "Ошибка загрузки фото: " + ex.Message;
            isError = true;
            StateHasChanged();
        }
    }

    private async Task AddPlacemark()
    {
        if (string.IsNullOrWhiteSpace(newPlacemark.Name))
        {
            message = "Введите название!";
            isError = true;
            return;
        }

        HttpResponseMessage response;
        if (editingId.HasValue)
        {
            response = await Http.PutAsJsonAsync($"/api/placemarks/{editingId.Value}", newPlacemark);
        }
        else
        {
            response = await Http.PostAsJsonAsync("/api/placemarks", newPlacemark);
        }

        if (response.IsSuccessStatusCode)
        {
            message = editingId.HasValue ? "Объект обновлён!" : "Объект добавлен!";
            isError = false;
            await Task.Delay(800);
            showForm = false;
            editingId = null;
            newPlacemark = new NewPlacemark();
            await LoadPlacemarks();
        }
        else
        {
            message = "Ошибка при сохранении";
            isError = true;
        }
    }

    private void CloseForm()
    {
        showForm = false;
        editingId = null;
        newPlacemark = new NewPlacemark();
        message = "";
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
        try { JS.InvokeVoidAsync("destroyMap"); } catch { }
    }

    public class PhotoUploadResult
    {
        public string FileName { get; set; } = "";
    }

    public class GeocodeResult
    {
        public double lat { get; set; }
        public double lon { get; set; }
        public string address { get; set; } = "";
    }

    public class ReverseResult
    {
        public string address { get; set; } = "";
    }

    public class GeocodeSuggestItem
    {
        public double lat { get; set; }
        public double lon { get; set; }
        public string address { get; set; } = "";
    }

    public class SuggestionResult
    {
        public List<GeocodeSuggestItem> items { get; set; } = new();
    }

    public class PlacemarkData
    {
        public int Id { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string Name { get; set; } = "";
        public string Address { get; set; } = "";
        public string Category { get; set; } = "";
        public string LevelText { get; set; } = "";
        public string Level { get; set; } = "";
        public int TotalScore { get; set; }
        public string Notes { get; set; } = "";
        public string? PhotoUrl { get; set; }
        public string? PhotoPath { get; set; }
        public string VerificationStatus { get; set; } = "pending";
        public PlacemarkScores? Scores { get; set; }
    }

    public class PlacemarkScores
    {
        public int Entrance { get; set; }
        public int DoorWidth { get; set; }
        public int InternalPath { get; set; }
        public int Sanitary { get; set; }
        public int Info { get; set; }
        public int Parking { get; set; }
        public int Staff { get; set; }
    }

    public class NewPlacemark
    {
        public string Name { get; set; } = "";
        public string Address { get; set; } = "";
        public string Category { get; set; } = "";
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int ScoreEntrance { get; set; }
        public int ScoreDoorWidth { get; set; }
        public int ScoreInternalPath { get; set; }
        public int ScoreSanitary { get; set; }
        public int ScoreInfo { get; set; }
        public int ScoreParking { get; set; }
        public int ScoreStaff { get; set; }
        public string Notes { get; set; } = "";
        public string PhotoPath { get; set; } = "";
    }
}
