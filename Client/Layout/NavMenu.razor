@inject AccessibilityMap.Services.AuthState Auth
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="topbar">
    <a class="brand" href="" @onclick="ClosePanels">♿ Карта доступности</a>
    <nav class="nav-links">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="ClosePanels">Карта</NavLink>
        @if (Auth.IsAuthenticated)
        {
            <NavLink class="nav-link" href="places" @onclick="ClosePanels">Список</NavLink>
        }
        @if (Auth.Role == "Manager" || Auth.Role == "Developer")
        {
            <NavLink class="nav-link" href="verify" @onclick="ClosePanels">Проверка</NavLink>
            <NavLink class="nav-link" href="users" @onclick="ClosePanels">Пользователи</NavLink>
            <NavLink class="nav-link" href="attachments" @onclick="ClosePanels">Вложения</NavLink>
        }
        @if (Auth.Role == "Developer")
        {
            <NavLink class="nav-link" href="logs" @onclick="ClosePanels">Журнал</NavLink>
        }
        @if (Auth.IsAuthenticated)
        {
            <NavLink class="nav-link" href="profile" @onclick="ClosePanels">Профиль</NavLink>
        }
        <NavLink class="nav-link" href="about" @onclick="ClosePanels">О проекте</NavLink>
        @if (!Auth.IsAuthenticated)
        {
            <NavLink class="nav-link nav-login" href="login" @onclick="ClosePanels">Вход</NavLink>
        }
    </nav>

    <div class="user-box user-box-near-tabs">
        @if (Auth.IsAuthenticated)
        {
            <span class="muted">@Auth.UserName · @RoleRu</span>
            <button class="btn btn-sm btn-secondary" @onclick="Logout">Выйти</button>
        }
        else
        {
            <span class="muted guest-label">Гость</span>
        }
    </div>

    <div class="ui-controls">
        <div class="ui-control-block">
            <div class="ui-control-label">Цветовая тема</div>
            <div class="theme-switch" title="Цветовая тема">
                <button class="theme-btn @(theme == "light" ? "active" : "")" @onclick='@(() => SetTheme("light"))'>☀️</button>
                <button class="theme-btn @(theme == "dark" ? "active" : "")" @onclick='@(() => SetTheme("dark"))'>🌙</button>
            </div>
        </div>
        <div class="ui-control-block">
            <div class="ui-control-label">Шрифт</div>
            <div class="font-switch" title="Шрифт">
                <button class="font-btn @(fontSize == "small" ? "active" : "")" @onclick='@(() => SetFont("small"))'>Мал</button>
                <button class="font-btn @(fontSize == "medium" ? "active" : "")" @onclick='@(() => SetFont("medium"))'>Сред</button>
                <button class="font-btn @(fontSize == "large" ? "active" : "")" @onclick='@(() => SetFont("large"))'>Больш</button>
            </div>
        </div>
    </div>
</div>
@if (Auth.IsAuthenticated && !Auth.ProfileComplete)
{
    <div class="profile-required-banner">Заполните ФИО и дату рождения в профиле, иначе рабочие функции недоступны.</div>
}

@code {
    private string theme = "light";
    private string fontSize = "medium";

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += HandleAuthChanged;
        Nav.LocationChanged += HandleLocationChanged;
        await Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                theme = await JS.InvokeAsync<string>("getUiPreference", "am_theme", "light");
                fontSize = await JS.InvokeAsync<string>("getUiPreference", "am_font", "medium");
                await JS.InvokeVoidAsync("applyUiPrefs");
                StateHasChanged();
            }
            catch { }
        }
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);
    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) => _ = ClosePanels();

    private string RoleRu => Auth.Role switch
    {
        "Developer" => "Разработчик",
        "Manager" => "Управляющий",
        "Volunteer" => "Волонтёр",
        _ => Auth.Role
    };

    private async Task SetTheme(string value)
    {
        theme = value;
        await JS.InvokeVoidAsync("setThemePreference", theme);
    }

    private async Task SetFont(string value)
    {
        fontSize = value;
        await JS.InvokeVoidAsync("setFontPreference", fontSize);
    }

    private async Task ClosePanels()
    {
        try { await JS.InvokeVoidAsync("closeMapPanels"); } catch { }
    }

    private async Task Logout()
    {
        try { await Http.PostAsync("/api/auth/logout", null); } catch { }
        await Auth.ClearAsync();
        await ClosePanels();
        Nav.NavigateTo("");
    }

    public void Dispose()
    {
        Auth.OnChange -= HandleAuthChanged;
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
