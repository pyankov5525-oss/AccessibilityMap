@inherits LayoutComponentBase
@inject AccessibilityMap.Services.AuthState Auth
@implements IDisposable

@if (Auth.IsAuthenticated)
{
    <div class="app-shell">
        <NavMenu />
        <main class="app-main">
            @Body
        </main>
    </div>
}
else
{
    <Login />
}

@code {
    protected override async Task OnInitializedAsync()
    {
        // Подписываемся ДО восстановления сессии, чтобы при появлении токена
        // из localStorage шелл сразу перерисовался (иначе после обновления
        // страницы пользователь «выкидывался» на форму входа).
        Auth.OnChange += StateHasChanged;
        await Auth.RestoreAsync();
    }

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
